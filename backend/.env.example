ENV=dev
LOG_LEVEL=DEBUG

# Local PostgreSQL (via `task db:up`)
DATABASE_URL=postgresql://orion:orion@localhost:5433/orion_dev

# Remote managed Postgres (e.g. Neon) — add `?sslmode=require` for SSL
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Firebase project ID (used by Firebase Admin when verifying tokens)
# FIREBASE_PROJECT_ID=orion-dev

# Anthropic Claude API — used by FEATURE-014 (LLM order import). Leave blank
# in dev/test environments — the import service degrades gracefully and the
# test suite mocks the HTTP transport via respx.
ANTHROPIC_API_KEY=

# Override the default Anthropic model. Falls back to a cheap Haiku tier so
# PDF parses stay inexpensive.
ANTHROPIC_MODEL=claude-haiku-4-5
