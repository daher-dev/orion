ENV=dev
LOG_LEVEL=DEBUG

# Local PostgreSQL (via `task db:up`)
DATABASE_URL=postgresql://orion:orion@localhost:5433/orion_dev

# Remote managed Postgres (e.g. Neon) — add `?sslmode=require` for SSL
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Firebase project ID (used by Firebase Admin when verifying tokens)
# FIREBASE_PROJECT_ID=orion-dev

# Comma-separated CORS origins. Required in prd (ENV=prd) — without it the
# deployed frontend is blocked. In dev the localhost origins are added
# automatically, so you usually leave this blank locally.
# ALLOWED_ORIGINS=https://beta.apporion.com.br,https://apporion.com.br

# Anthropic Claude API — used by FEATURE-014 (LLM order import). Leave blank
# in dev/test environments — the import service degrades gracefully and the
# test suite mocks the HTTP transport via respx.
ANTHROPIC_API_KEY=

# Override the default Anthropic model. Falls back to a cheap Haiku tier so
# PDF parses stay inexpensive.
ANTHROPIC_MODEL=claude-haiku-4-5

# base44 → Orion data migration (backend/scripts/base44/). Only the importer
# scripts read these — leave blank for normal app/dev runs. Set them when
# running `task db:base44:discover` / `task db:base44:import`.
#   BASE44_APP_ID          legacy app id (from the base44 editor URL, /apps/<id>/editor)
#   BASE44_API_TOKEN       bearer token with read access to the app's entities
#   BASE44_TARGET_SUBDOMAIN  subdomain of the Orion company to import into
# BASE44_API_URL=https://base44.app
BASE44_APP_ID=
BASE44_API_TOKEN=
BASE44_TARGET_SUBDOMAIN=
