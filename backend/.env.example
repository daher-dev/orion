ENV=dev
LOG_LEVEL=DEBUG

# Local PostgreSQL (via `task db:up`)
DATABASE_URL=postgresql://orion:orion@localhost:5433/orion_dev

# Remote managed Postgres (e.g. Neon) — add `?sslmode=require` for SSL
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Firebase project ID (used by Firebase Admin when verifying tokens)
# FIREBASE_PROJECT_ID=orion-dev

# Anthropic Claude API — used in Wave 5 (LLM order import). Leave blank for now.
ANTHROPIC_API_KEY=
